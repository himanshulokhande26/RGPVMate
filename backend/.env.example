# ──────────────────────────────────────────
# RGPVMate Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rgpvmate?retryWrites=true&w=majority

# Google Gemini API — used as FINAL FALLBACK when all Groq keys are rate-limited
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API — 14,400 req/day FREE per key (llama-3.1-8b-instant / llama-3.3-70b-versatile)
# Add up to 3+ keys comma-separated for automatic round-robin rotation
# Get your keys at: https://console.groq.com
GROQ_API_KEYS=your_groq_key_1_here,your_groq_key_2_here,your_groq_key_3_here
GROQ_MODEL=llama-3.1-8b-instant

# Token tuning (optional — safe defaults shown)
# MAX_CHUNK_CHARS: max chars per retrieved chunk sent to LLM (1200 ≈ 300 tokens)
MAX_CHUNK_CHARS=1200

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Panel
ADMIN_PASSWORD=your_admin_password_here

# Python Embedder Service
# Local dev: http://localhost:5000
# Production: https://rgpvmate-embedder.onrender.com
EMBEDDER_URL=http://localhost:5000

# Frontend URL (for CORS)
# Local dev: http://localhost:3001
# Production: https://rgpvmate.vercel.app
FRONTEND_URL=http://localhost:3001

# Qdrant Cloud Vector Database
# Local dev (Docker): http://localhost:6333
# Production (Qdrant Cloud endpoint): https://xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=your_qdrant_endpoint_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
