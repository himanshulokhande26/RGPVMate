# ──────────────────────────────────────────
# RGPVMate Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rgpvmate?retryWrites=true&w=majority

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Panel
ADMIN_PASSWORD=your_admin_password_here

# Python Embedder Service
# Local dev: http://localhost:5000
# Production: https://rgpvmate-embedder.onrender.com
EMBEDDER_URL=http://localhost:5000

# Frontend URL (for CORS)
# Local dev: http://localhost:3001
# Production: https://rgpvmate.vercel.app
FRONTEND_URL=http://localhost:3001

# Qdrant Cloud Vector Database
# Local dev (Docker): http://localhost:6333
# Production (Qdrant Cloud endpoint): https://xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=your_qdrant_endpoint_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
