# ─────────────────────────────────────────
# RGPVMate — .gitignore
# ─────────────────────────────────────────

# ── Environment / Secrets ─────────────────
.env
.env.local
.env.production
.env.*.local

# ── Node.js ───────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Next.js / React ───────────────────────
.next/
out/
.vercel

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Uploaded / temp PDFs ──────────────────
# Keep the /documents folder structure but ignore actual PDFs
# (PDFs are large and shouldn't be version-controlled)
documents/**/*.pdf
backend/documents/tmp/
documents/

# ── ChromaDB local data ───────────────────
chroma_data/
*.chroma

# ── Logs ──────────────────────────────────
logs/
*.log

# ── Scraper auto-generated output ─────────
# These are regenerated by 'npm run scrape' and should not be version-controlled
documents/unmapped_titles.txt
documents/unmapped_scheme_titles.txt
documents/syllabus/_debug_*.png

# ── Misc ──────────────────────────────────
*.zip
*.tar.gz
.cache/


# ── Agent ──────────────────────────────────
.antigravitycli